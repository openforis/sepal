{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/unsupervisedClassification/schema.json",
    "title": "UnsupervisedClassificationRecipe",
    "description": "A SEPAL Unsupervised Classification recipe. Cluster pixels of one or more input images into N classes without training data, using K-means or one of its variants (LVQ, X-means, Cascade-K-means, Cobweb).\n\n**Pipeline.** (1) Stack input images plus optional auxiliary imagery into a feature image. (2) Sample `sampling.numberOfSamples` random pixels at `sampling.sampleScale` meters. (3) Train the configured clusterer on the samples. (4) Apply per-pixel — output is a `class` band.\n\n**Bands produced.** Always `class` (uint8 — cluster id 0..N-1).\n\n**AOI semantics.** No separate AOI field — implicit in the input imagery.",
    "type": "object",
    "additionalProperties": true,
    "required": ["inputImagery", "sampling", "auxiliaryImagery", "clusterer"],
    "properties": {
        "inputImagery": {"$ref": "#/$defs/inputImagery"},
        "sampling": {"$ref": "#/$defs/sampling"},
        "auxiliaryImagery": {"$ref": "#/$defs/auxiliaryImagery"},
        "clusterer": {"$ref": "#/$defs/clusterer"},
        "scale": {"type": "number", "exclusiveMinimum": 0}
    },
    "$defs": {
        "inputImagery": {
            "title": "UnsupervisedInputImagery",
            "type": "object",
            "additionalProperties": true,
            "required": ["images"],
            "properties": {
                "images": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["imageId", "type", "id", "bands", "bandSetSpecs"],
                        "properties": {
                            "imageId": {"type": "string", "minLength": 1},
                            "type": {"enum": ["RECIPE_REF", "ASSET"]},
                            "id": {"type": "string", "minLength": 1},
                            "bands": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                            "bandSetSpecs": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "required": ["id", "type", "included"],
                                    "properties": {
                                        "id": {"type": "string"},
                                        "type": {"enum": ["IMAGE_BANDS", "PAIR_WISE_EXPRESSION", "INDEXES"]},
                                        "operation": {"enum": ["RATIO", "NORMALIZED_DIFFERENCE", "DIFFERENCE", "DISTANCE", "ANGLE"]},
                                        "included": {"type": "array", "items": {"type": "string"}}
                                    },
                                    "allOf": [
                                        {
                                            "if": {"properties": {"type": {"const": "PAIR_WISE_EXPRESSION"}}, "required": ["type"]},
                                            "then": {"required": ["operation"]}
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "sampling": {
            "title": "UnsupervisedSampling",
            "description": "Random-pixel sampling configuration for training the clusterer.",
            "type": "object",
            "additionalProperties": false,
            "required": ["numberOfSamples", "sampleScale"],
            "properties": {
                "numberOfSamples": {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 2147483647,
                    "description": "How many random pixels to sample. Default `10000`."
                },
                "sampleScale": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "description": "Sampling scale in meters. Default `10`."
                }
            }
        },
        "auxiliaryImagery": {
            "title": "UnsupervisedAuxiliaryImagery",
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["LATITUDE", "TERRAIN", "WATER"]},
            "description": "Optional auxiliary feature layers. Same as classification: LATITUDE, TERRAIN, WATER."
        },
        "clusterer": {
            "title": "UnsupervisedClusterer",
            "description": "Clustering algorithm and hyperparameters. The `type` discriminates among 4 algorithms; each has its own required parameters.\n\n- `KMEANS` — Weka SimpleKMeans. Most common; needs `numberOfClusters`.\n- `LVQ` — Learning Vector Quantization. Needs `numberOfClusters`, `learningRate`, `epochs`.\n- `XMEANS` — Variable-K K-means. Needs `minNumberOfClusters`, `maxNumberOfClusters`.\n- `CASCADE_KMEANS` — Weka cascade simple K-means. Needs `minNumberOfClusters`, `maxNumberOfClusters`, `restarts`.\n\nNote: the legacy schema also listed `COBWEB`, but the EE backend's `createClusterer` throws \"Unsupported clusterer type\" for it.",
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "tileScale", "normalize"],
            "properties": {
                "type": {"enum": ["KMEANS", "LVQ", "XMEANS", "CASCADE_KMEANS"]},
                "tileScale": {
                    "type": "number",
                    "minimum": 0.1,
                    "maximum": 16,
                    "description": "Tile-scale multiplier passed to EE reducers. Default `1`. Increase (2, 4, 8) to avoid out-of-memory on large AOIs."
                },
                "normalize": {
                    "enum": ["YES", "NO"],
                    "description": "Whether to per-band unit-scale features before clustering. Default `YES`."
                },
                "numberOfClusters": {
                    "type": "integer",
                    "minimum": 2,
                    "description": "Required for KMEANS / LVQ. The fixed number of clusters."
                },
                "minNumberOfClusters": {"type": "integer", "minimum": 1, "description": "Required for XMEANS / CASCADE_KMEANS."},
                "maxNumberOfClusters": {"type": "integer", "minimum": 2, "description": "Required for XMEANS / CASCADE_KMEANS."},
                "restarts": {"type": "integer", "minimum": 0, "description": "CASCADE_KMEANS only."},
                "init": {"type": "integer", "minimum": 0, "maximum": 3, "description": "CASCADE_KMEANS / KMEANS — initialization strategy index."},
                "distanceFunction": {
                    "type": "string",
                    "minLength": 1,
                    "description": "CASCADE_KMEANS / KMEANS / XMEANS — distance metric."
                },
                "maxIterations": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "CASCADE_KMEANS / KMEANS."},
                "canopies": {"description": "KMEANS only — boolean toggle."},
                "maxCandidates": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "KMEANS only."},
                "periodicPruning": {"type": "integer", "minimum": 0, "maximum": 2147483647, "description": "KMEANS only."},
                "minDensity": {"type": "integer", "minimum": 0, "maximum": 2147483647, "description": "KMEANS only."},
                "t1": {"type": "number", "description": "KMEANS canopy threshold."},
                "t2": {"type": "number", "description": "KMEANS canopy threshold."},
                "preserveOrder": {"description": "KMEANS only — boolean."},
                "fast": {"description": "KMEANS only — boolean."},
                "seed": {"type": "integer", "description": "KMEANS / XMEANS — random seed."},
                "learningRate": {"type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "LVQ only."},
                "epochs": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "LVQ only."},
                "maxIterationsOverall": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "maxKMeans": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "maxForChildren": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "useKD": {"description": "XMEANS only — boolean."},
                "cutoffFactor": {"type": "number", "description": "XMEANS only."}
            },
            "allOf": [
                {
                    "if": {"properties": {"type": {"enum": ["KMEANS", "LVQ"]}}, "required": ["type"]},
                    "then": {"required": ["numberOfClusters"]}
                },
                {
                    "if": {"properties": {"type": {"enum": ["XMEANS", "CASCADE_KMEANS"]}}, "required": ["type"]},
                    "then": {"required": ["minNumberOfClusters", "maxNumberOfClusters"]}
                },
                {
                    "if": {"properties": {"type": {"const": "CASCADE_KMEANS"}}, "required": ["type"]},
                    "then": {"required": ["restarts"]}
                },
                {
                    "if": {"properties": {"type": {"const": "LVQ"}}, "required": ["type"]},
                    "then": {"required": ["learningRate", "epochs"]}
                }
            ]
        }
    }
}

#!/bin/sh
# provision-user <username> <uid> <gid>
# Creates the SSH home (+ RSA keypair) and the SEPAL data home for a user, owned by the user.
# <uid>/<gid> are the real POSIX numbers (migrated from LDAP, or = sepal_user.id for users created by
# user-node); they may differ from each other and from the DB id. The SEPAL data dir is group-owned
# by the local sepal group 9999.
# Idempotent: an existing keypair is not regenerated. Prints the SSH public key to stdout.
set -e

username="$1"
uid="$2"
gid="$3"
sepal_gid=9999
user_home="/home/$username"
data_home="/sepal/home/$username"

if [ -z "$username" ] || [ -z "$uid" ] || [ -z "$gid" ]; then
    echo "usage: provision-user <username> <uid> <gid>" >&2
    exit 2
fi

# Reject anything but a safe username (defense in depth — this runs as root via sudo).
# Only [A-Za-z0-9_] allowed: blocks path traversal (/, ..), globs, spaces, and shell metacharacters.
case "$username" in
    "" | *[!A-Za-z0-9_]* ) echo "invalid username: $username" >&2; exit 2 ;;
esac
# uid/gid must be plain integers (they are interpolated into chown, which runs as root).
case "$uid" in "" | *[!0-9]* ) echo "invalid uid: $uid" >&2; exit 2 ;; esac
case "$gid" in "" | *[!0-9]* ) echo "invalid gid: $gid" >&2; exit 2 ;; esac

# SSH home + key pair
mkdir -p "$user_home/.ssh"
printf '%s\n' 'Host *' '    StrictHostKeyChecking no' '    UserKnownHostsFile /dev/null' '    LogLevel QUIET' \
    > "$user_home/.ssh/config"
if [ ! -f "$user_home/.ssh/id_rsa" ]; then
    ssh-keygen -t rsa -b 4096 -C "Sandbox key for $username" -f "$user_home/.ssh/id_rsa" -N "" >/dev/null
fi
chmod -R 770 "$user_home"
chown -R "$uid:$gid" "$user_home"
chmod 400 "$user_home"/.ssh/*

# SEPAL data home (group-owned by the sepal group, setgid)
mkdir -p "$data_home/downloads"
chown -R "$uid:$sepal_gid" "$data_home"
chmod -R 770 "$data_home"
chmod -R g+s "$data_home"

cat "$user_home/.ssh/id_rsa.pub"

#!/bin/sh
# delete-credentials <username>
# Removes the user's Earth Engine credentials file. Runs as root via sudo.
set -e

username="$1"
case "$username" in
    "" | *[!A-Za-z0-9_]* ) echo "invalid username: $username" >&2; exit 2 ;;
esac

rm -f "/sepal/home/$username/.config/earthengine/credentials"

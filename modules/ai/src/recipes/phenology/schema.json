{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/phenology/schema.json",
    "title": "PhenologyRecipe",
    "description": "Per-pixel seasonal vegetation-cycle metrics — start/end of season, peak greenness, amplitude, length — from a multi-year vegetation-index series.\n\nOutputs:\n- Summary: `background`, `amplitude`, `median`.\n- Per-season (1, 2): `dayOfYear_<n>`, `days_<n>`, `median_<n>`, `slope_<n>`, `offset_<n>`.\n- Monthly: `january`..`december`.\n\nPipeline: build time series of `sources.band` (typically `evi`/`ndvi`) across `dates.fromYear..toYear` → per-pixel seasonal fit → extract metrics. Optical only (LS/S2).",
    "type": "object",
    "additionalProperties": true,
    "required": ["aoi", "dates", "sources"],
    "properties": {
        "aoi": {
            "oneOf": [
                {"$ref": "../shared/aoi.schema.json#/$defs/eeTable"},
                {"$ref": "../shared/aoi.schema.json#/$defs/polygon"}
            ]
        },
        "dates": {"$ref": "#/$defs/dates"},
        "sources": {"$ref": "#/$defs/sources"},
        "options": {
            "title": "PhenologyOptions",
            "description": "Same shape as `TIME_SERIES.options`. See that schema for per-field semantics.",
            "$ref": "../timeSeries/schema.json#/$defs/options"
        }
    },
    "$defs": {
        "dates": {
            "title": "PhenologyDates",
            "description": "Both endpoints inclusive — `fromYear` AND `toYear` included.",
            "type": "object",
            "additionalProperties": false,
            "required": ["fromYear", "toYear"],
            "properties": {
                "fromYear": {"type": "integer", "minimum": 1972, "description": "First year."},
                "toYear": {"type": "integer", "minimum": 1972, "description": "Last year. Must be ≥ fromYear."}
            }
        },
        "sources": {
            "title": "PhenologySources",
            "type": "object",
            "additionalProperties": true,
            "required": ["cloudPercentageThreshold", "dataSets", "band"],
            "properties": {
                "cloudPercentageThreshold": {"type": "integer", "minimum": 0, "maximum": 100, "description": "Drop scenes above this scene-level cloud %. Default 75."},
                "dataSets": {
                    "type": "object",
                    "additionalProperties": false,
                    "minProperties": 1,
                    "properties": {
                        "LANDSAT": {
                            "type": "array",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {"enum": ["LANDSAT_9", "LANDSAT_8", "LANDSAT_7", "LANDSAT_TM", "LANDSAT_9_T2", "LANDSAT_8_T2", "LANDSAT_7_T2", "LANDSAT_TM_T2"]}
                        },
                        "SENTINEL_2": {
                            "type": "array",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {"enum": ["SENTINEL_2"]}
                        }
                    }
                },
                "band": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Vegetation index band. Common: `evi` (default), `evi2`, `ndvi`, `ndmi`, `nbr`, `savi`, `kndvi`."
                }
            }
        }
    }
}

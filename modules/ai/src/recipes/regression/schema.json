{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/regression/schema.json",
    "title": "RegressionRecipe",
    "description": "Predict a continuous per-pixel value from training points using RF, GBT, or CART (only these support regression in EE).\n\nPipeline: stack input images + optional auxiliary → sample training points → train regressor → apply per-pixel. Output: single `regression` band of float values.\n\nAOI implicit in input imagery. See `classification` schema for full per-field semantics — same hyperparameter set, just continuous targets instead of class labels.",
    "type": "object",
    "additionalProperties": true,
    "required": ["inputImagery", "trainingData", "auxiliaryImagery", "classifier"],
    "properties": {
        "inputImagery": {"$ref": "#/$defs/inputImagery"},
        "trainingData": {"$ref": "#/$defs/trainingData"},
        "auxiliaryImagery": {"$ref": "#/$defs/auxiliaryImagery"},
        "classifier": {"$ref": "#/$defs/classifier"},
        "scale": {"type": "number", "exclusiveMinimum": 0, "description": "Per-pixel processing scale (m). Omit to use input's native scale."}
    },
    "$defs": {
        "inputImagery": {
            "title": "RegressionInputImagery",
            "description": "Source images. Same shape as classification.inputImagery.",
            "type": "object",
            "additionalProperties": true,
            "required": ["images"],
            "properties": {
                "images": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["imageId", "type", "id", "bands", "bandSetSpecs"],
                        "properties": {
                            "imageId": {"type": "string", "description": "UUID."},
                            "type": {"enum": ["RECIPE_REF", "ASSET"]},
                            "id": {"type": "string", "description": "SEPAL recipe id or EE asset id."},
                            "bands": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "Bands the source exposes."},
                            "bandSetSpecs": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "required": ["id", "type", "included"]
                                },
                                "description": "Band selection / derivation specs (IMAGE_BANDS, PAIR_WISE_EXPRESSION, INDEXES). See classification schema."
                            }
                        }
                    }
                }
            }
        },
        "trainingData": {
            "title": "RegressionTrainingData",
            "description": "Training points with continuous target values (real-valued, not class labels). Same shape as classification.trainingData.",
            "type": "object",
            "additionalProperties": false,
            "required": ["dataSets"],
            "properties": {
                "dataSets": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["dataSetId", "name", "type"],
                        "properties": {
                            "dataSetId": {"type": "string", "description": "UUID."},
                            "name": {"type": "string"},
                            "type": {"enum": ["COLLECTED", "RECIPE", "EE_TABLE", "CSV_UPLOAD", "SAMPLE_CLASSIFICATION", "CEO"]}
                        }
                    }
                }
            }
        },
        "auxiliaryImagery": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["LATITUDE", "TERRAIN", "WATER"]},
            "description": "Optional aux feature layers. LATITUDE / TERRAIN (SRTM 30 m, recommended in mountainous regions) / WATER (JRC GSW). Default `[]`. Each adds compute cost."
        },
        "classifier": {
            "title": "RegressionClassifier",
            "description": "Algorithm + hyperparameters. Only RF, GBT, CART supported (EE constraint). See classification schema for per-parameter semantics.",
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
                "type": {"enum": ["RANDOM_FOREST", "GRADIENT_TREE_BOOST", "CART"]},
                "numberOfTrees": {"type": "integer", "minimum": 1, "description": "Trees (RF + GBT). Default 25."},
                "variablesPerSplit": {"type": ["integer", "null"], "minimum": 1, "description": "mtry (RF). null → √(numFeatures)."},
                "minLeafPopulation": {"type": "integer", "minimum": 1, "description": "Min training samples per leaf (RF + CART). Default 1."},
                "bagFraction": {"type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "Bag fraction (RF). Default 0.5."},
                "maxNodes": {"type": ["integer", "null"], "minimum": 2, "description": "Hard cap on nodes per tree. null = unbounded."},
                "seed": {"type": "integer", "description": "Random seed (RF + GBT). Default 1."},
                "shrinkage": {"type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "GBT learning rate. Default 0.005."},
                "samplingRate": {"type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "GBT per-tree subsample. Default 0.7."},
                "loss": {"enum": ["LeastSquares", "LeastAbsoluteDeviation", "Huber"], "description": "GBT loss. `LeastAbsoluteDeviation` (default) = robust to outliers."}
            },
            "allOf": [
                {
                    "if": {"properties": {"type": {"const": "RANDOM_FOREST"}}, "required": ["type"]},
                    "then": {"required": ["numberOfTrees", "minLeafPopulation", "bagFraction", "seed"]}
                },
                {
                    "if": {"properties": {"type": {"const": "GRADIENT_TREE_BOOST"}}, "required": ["type"]},
                    "then": {"required": ["numberOfTrees", "shrinkage", "samplingRate", "loss", "seed"]}
                },
                {
                    "if": {"properties": {"type": {"const": "CART"}}, "required": ["type"]},
                    "then": {"required": ["minLeafPopulation"]}
                }
            ]
        }
    }
}

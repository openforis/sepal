{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/unsupervisedClassification/schema.json",
    "title": "UnsupervisedClassificationRecipe",
    "description": "Cluster pixels into N groups without training data (K-means + variants).\n\nPipeline: stack inputs + aux → sample `numberOfSamples` random pixels at `sampleScale` m → train clusterer → apply per-pixel. Output: `class` band (uint8, cluster id 0..N−1).\n\nAOI implicit in input imagery.",
    "type": "object",
    "additionalProperties": true,
    "required": ["inputImagery", "sampling", "auxiliaryImagery", "clusterer"],
    "properties": {
        "inputImagery": {"$ref": "#/$defs/inputImagery"},
        "sampling": {"$ref": "#/$defs/sampling"},
        "auxiliaryImagery": {"$ref": "#/$defs/auxiliaryImagery"},
        "clusterer": {"$ref": "#/$defs/clusterer"},
        "scale": {"type": "number", "exclusiveMinimum": 0, "description": "Per-pixel processing scale (m). Omit to use input's native scale."}
    },
    "$defs": {
        "inputImagery": {
            "title": "UnsupervisedInputImagery",
            "description": "Source images. Same shape as classification.inputImagery.",
            "type": "object",
            "additionalProperties": true,
            "required": ["images"],
            "properties": {
                "images": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["imageId", "type", "id", "bands", "bandSetSpecs"],
                        "properties": {
                            "imageId": {"type": "string", "minLength": 1, "description": "UUID."},
                            "type": {"enum": ["RECIPE_REF", "ASSET"]},
                            "id": {"type": "string", "minLength": 1, "description": "SEPAL recipe id or EE asset id."},
                            "bands": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "Bands the source exposes."},
                            "bandSetSpecs": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "required": ["id", "type", "included"],
                                    "properties": {
                                        "id": {"type": "string"},
                                        "type": {"enum": ["IMAGE_BANDS", "PAIR_WISE_EXPRESSION", "INDEXES"]},
                                        "operation": {"enum": ["RATIO", "NORMALIZED_DIFFERENCE", "DIFFERENCE", "DISTANCE", "ANGLE"]},
                                        "included": {"type": "array", "items": {"type": "string"}}
                                    },
                                    "allOf": [
                                        {
                                            "if": {"properties": {"type": {"const": "PAIR_WISE_EXPRESSION"}}, "required": ["type"]},
                                            "then": {"required": ["operation"]}
                                        }
                                    ]
                                },
                                "description": "Band selection / derivation specs. See classification schema."
                            }
                        }
                    }
                }
            }
        },
        "sampling": {
            "title": "UnsupervisedSampling",
            "description": "Random-pixel sampling for clusterer training.",
            "type": "object",
            "additionalProperties": false,
            "required": ["numberOfSamples", "sampleScale"],
            "properties": {
                "numberOfSamples": {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 2147483647,
                    "description": "Sample count. Default 10000."
                },
                "sampleScale": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "description": "Sampling scale (m). Default 10."
                }
            }
        },
        "auxiliaryImagery": {
            "title": "UnsupervisedAuxiliaryImagery",
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["LATITUDE", "TERRAIN", "WATER"]},
            "description": "Optional aux feature layers. LATITUDE / TERRAIN (SRTM 30 m, recommended in mountainous regions) / WATER (JRC GSW). Default `[]`."
        },
        "clusterer": {
            "title": "UnsupervisedClusterer",
            "description": "Algorithm + hyperparameters. `type` discriminates:\n- `KMEANS` — Weka SimpleKMeans. Default choice. Needs `numberOfClusters`.\n- `LVQ` — Learning Vector Quantization. Needs `numberOfClusters`, `learningRate`, `epochs`.\n- `XMEANS` — variable-K K-means. Needs `minNumberOfClusters`, `maxNumberOfClusters`.\n- `CASCADE_KMEANS` — cascade simple K-means. Needs `minNumberOfClusters`, `maxNumberOfClusters`, `restarts`.\n\nLegacy `COBWEB` is rejected by EE backend — don't use.",
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "tileScale", "normalize"],
            "properties": {
                "type": {"enum": ["KMEANS", "LVQ", "XMEANS", "CASCADE_KMEANS"]},
                "tileScale": {
                    "type": "number",
                    "minimum": 0.1,
                    "maximum": 16,
                    "description": "EE reducer tile-scale. Default 1. Bump (2/4/8) on OOM for large AOIs."
                },
                "normalize": {
                    "enum": ["YES", "NO"],
                    "description": "Per-band unit-scale before clustering. Default `YES` (recommended unless features already comparable)."
                },
                "numberOfClusters": {"type": "integer", "minimum": 2, "description": "KMEANS / LVQ — fixed cluster count."},
                "minNumberOfClusters": {"type": "integer", "minimum": 1, "description": "XMEANS / CASCADE_KMEANS."},
                "maxNumberOfClusters": {"type": "integer", "minimum": 2, "description": "XMEANS / CASCADE_KMEANS."},
                "restarts": {"type": "integer", "minimum": 0, "description": "CASCADE_KMEANS only."},
                "init": {"type": "integer", "minimum": 0, "maximum": 3, "description": "KMEANS / CASCADE_KMEANS init strategy index."},
                "distanceFunction": {"type": "string", "minLength": 1, "description": "KMEANS / XMEANS / CASCADE_KMEANS distance metric."},
                "maxIterations": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "KMEANS / CASCADE_KMEANS."},
                "canopies": {"description": "KMEANS — boolean."},
                "maxCandidates": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "KMEANS only."},
                "periodicPruning": {"type": "integer", "minimum": 0, "maximum": 2147483647, "description": "KMEANS only."},
                "minDensity": {"type": "integer", "minimum": 0, "maximum": 2147483647, "description": "KMEANS only."},
                "t1": {"type": "number", "description": "KMEANS canopy threshold."},
                "t2": {"type": "number", "description": "KMEANS canopy threshold."},
                "preserveOrder": {"description": "KMEANS — boolean."},
                "fast": {"description": "KMEANS — boolean."},
                "seed": {"type": "integer", "description": "KMEANS / XMEANS random seed."},
                "learningRate": {"type": "number", "exclusiveMinimum": 0, "maximum": 1, "description": "LVQ only."},
                "epochs": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "LVQ only."},
                "maxIterationsOverall": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "maxKMeans": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "maxForChildren": {"type": "integer", "minimum": 1, "maximum": 2147483647, "description": "XMEANS only."},
                "useKD": {"description": "XMEANS — boolean."},
                "cutoffFactor": {"type": "number", "description": "XMEANS only."}
            },
            "allOf": [
                {
                    "if": {"properties": {"type": {"enum": ["KMEANS", "LVQ"]}}, "required": ["type"]},
                    "then": {"required": ["numberOfClusters"]}
                },
                {
                    "if": {"properties": {"type": {"enum": ["XMEANS", "CASCADE_KMEANS"]}}, "required": ["type"]},
                    "then": {"required": ["minNumberOfClusters", "maxNumberOfClusters"]}
                },
                {
                    "if": {"properties": {"type": {"const": "CASCADE_KMEANS"}}, "required": ["type"]},
                    "then": {"required": ["restarts"]}
                },
                {
                    "if": {"properties": {"type": {"const": "LVQ"}}, "required": ["type"]},
                    "then": {"required": ["learningRate", "epochs"]}
                }
            ]
        }
    }
}

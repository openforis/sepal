{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/ccdc/schema.json",
    "title": "CcdcRecipe",
    "description": "Continuous Change Detection and Classification. Per-pixel piecewise harmonic regression on a time series; emits segment coefficients + breakpoints. Output is consumed via `CCDC_SLICE` to render synthetic imagery at a chosen date.\n\nOutputs: multi-band image with per-segment intercept/slope/harmonic coefficients (annual, biannual, triannual) per breakpoint band + break dates.\n\nPipeline: filter `sources.breakpointBands` over AOI + dates → `ee.Algorithms.TemporalSegmentation.Ccdc` per pixel with `ccdcOptions` → persist segments + breaks.",
    "type": "object",
    "additionalProperties": true,
    "required": ["aoi", "dates", "sources", "ccdcOptions"],
    "properties": {
        "aoi": {
            "oneOf": [
                {"$ref": "../shared/aoi.schema.json#/$defs/eeTable"},
                {"$ref": "../shared/aoi.schema.json#/$defs/polygon"}
            ]
        },
        "dates": {"$ref": "#/$defs/dates"},
        "sources": {"$ref": "#/$defs/sources"},
        "options": {
            "title": "CcdcOptions",
            "description": "Same shape as `TIME_SERIES.options`. See that schema for per-field semantics.",
            "$ref": "../timeSeries/schema.json#/$defs/options"
        },
        "ccdcOptions": {"$ref": "#/$defs/ccdcOptions"}
    },
    "$defs": {
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$", "format": "date"},
        "dates": {
            "type": "object",
            "additionalProperties": false,
            "required": ["startDate", "endDate"],
            "properties": {
                "startDate": {"$ref": "#/$defs/date", "description": "Inclusive."},
                "endDate": {"$ref": "#/$defs/date", "description": "Exclusive. Full year 2024 → 2025-01-01."}
            }
        },
        "sources": {
            "type": "object",
            "additionalProperties": true,
            "required": ["dataSets", "breakpointBands"],
            "properties": {
                "cloudPercentageThreshold": {"type": "integer", "minimum": 0, "maximum": 100, "description": "Drop scenes above this scene-level cloud %. Default 75."},
                "dataSets": {
                    "type": "object",
                    "additionalProperties": false,
                    "minProperties": 1,
                    "properties": {
                        "LANDSAT": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["LANDSAT_9", "LANDSAT_8", "LANDSAT_7", "LANDSAT_TM", "LANDSAT_9_T2", "LANDSAT_8_T2", "LANDSAT_7_T2", "LANDSAT_TM_T2"]}},
                        "SENTINEL_2": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["SENTINEL_2"]}},
                        "SENTINEL_1": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["SENTINEL_1"]}}
                    }
                },
                "breakpointBands": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"type": "string"},
                    "description": "Bands used for break detection. Common: `ndfi` (default), `ndvi`, `nbr`, `swir1`, `nir`. More bands → more breaks but more cost."
                }
            }
        },
        "ccdcOptions": {
            "title": "CcdcAlgorithmOptions",
            "description": "`ee.Algorithms.TemporalSegmentation.Ccdc` tuning. GUI presets vary `minObservations` + `chiSquareProbability`: conservative (6, 0.99) / moderate (6, 0.9) / aggressive (4, 0.75).",
            "type": "object",
            "additionalProperties": false,
            "required": ["dateFormat", "minObservations", "chiSquareProbability", "minNumOfYearsScaler", "lambda", "maxIterations"],
            "properties": {
                "dateFormat": {
                    "type": "integer",
                    "enum": [0, 1, 2],
                    "description": "Output date encoding: 0=jDays, 1=fractional years (default), 2=unix ms."
                },
                "minObservations": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Min observations to fit a segment. Default 6."
                },
                "chiSquareProbability": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "χ² probability threshold for break detection. Higher = fewer false breaks. Default 0.9."
                },
                "minNumOfYearsScaler": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "description": "Min-years scaler. Default 1.33."
                },
                "lambda": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "description": "L1 regularization weight. Default 20."
                },
                "maxIterations": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Max solver iterations. Default 25000."
                }
            }
        }
    }
}

{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sepal.io/recipes/timeSeries/schema.json",
    "title": "TimeSeriesRecipe",
    "description": "A SEPAL Time Series recipe. Builds a per-pixel time series of observations across an AOI from optical (Landsat / Sentinel-2 / Planet) and/or radar (Sentinel-1) sources, between `dates.startDate` and `dates.endDate`. Used for further analysis (CCDC, phenology, regression) — the recipe itself produces a multi-band 'count' image and supports time-series visualization through the chartPixel UI.\n\n**Pipeline.** (1) Filter each source's collection by AOI bounds and the date range. (2) Apply per-source preprocessing (optical: SR/BRDF/cloud masks; radar: speckle filter / terrain correction). (3) Stack scenes per pixel into a time series.\n\n**Multi-source `options`.** This recipe combines optical mosaic, radar mosaic, and Planet mosaic options under a single `options` key. The applicable subset depends on which `sources.dataSets` groups are selected. Validation does not enforce per-group conditional applicability — extra fields are tolerated.",
    "type": "object",
    "additionalProperties": true,
    "required": ["aoi", "dates", "sources"],
    "properties": {
        "aoi": {
            "oneOf": [
                {"$ref": "../shared/aoi.schema.json#/$defs/eeTable"},
                {"$ref": "../shared/aoi.schema.json#/$defs/polygon"}
            ]
        },
        "dates": {"$ref": "#/$defs/dates"},
        "sources": {"$ref": "#/$defs/sources"},
        "options": {"$ref": "#/$defs/options"}
    },
    "$defs": {
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$", "format": "date"},
        "dates": {
            "title": "TimeSeriesDates",
            "type": "object",
            "additionalProperties": false,
            "required": ["startDate", "endDate"],
            "properties": {
                "startDate": {"$ref": "#/$defs/date", "description": "**Inclusive** start of the time series. Earliest useful values: 1972-07-23 (Landsat MSS), 1984 (TM), 2014-06-15 (Sentinel-1), 2015 (Sentinel-2)."},
                "endDate": {"$ref": "#/$defs/date", "description": "**Exclusive** end. Scenes acquired ON endDate are NOT included. For the full year 2024 set endDate=2025-01-01."}
            }
        },
        "sources": {
            "title": "TimeSeriesSources",
            "type": "object",
            "additionalProperties": false,
            "required": ["dataSets"],
            "properties": {
                "dataSets": {
                    "type": "object",
                    "additionalProperties": false,
                    "minProperties": 1,
                    "description": "Map of source group → datasets. At least one group required.",
                    "properties": {
                        "LANDSAT": {
                            "type": "array",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {"enum": ["LANDSAT_9", "LANDSAT_8", "LANDSAT_7", "LANDSAT_TM", "LANDSAT_9_T2", "LANDSAT_8_T2", "LANDSAT_7_T2", "LANDSAT_TM_T2"]}
                        },
                        "SENTINEL_2": {
                            "type": "array",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {"enum": ["SENTINEL_2"]}
                        },
                        "SENTINEL_1": {
                            "type": "array",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {"enum": ["SENTINEL_1"]}
                        }
                    }
                },
                "cloudPercentageThreshold": {"type": "integer", "minimum": 0, "maximum": 100}
            }
        },
        "options": {
            "title": "TimeSeriesOptions",
            "description": "Combined optical + radar processing options. Optical fields apply when `sources.dataSets.LANDSAT` or `SENTINEL_2` is present; radar fields apply when `SENTINEL_1` is present. Loosely structured — the EE backend ignores fields that don't apply to the selected sources.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "corrections": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {"enum": ["SR", "BRDF", "CALIBRATE"]},
                    "description": "Optical: applied corrections."
                },
                "brdfMultiplier": {"type": "number", "exclusiveMinimum": 0},
                "orbits": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {"enum": ["ASCENDING", "DESCENDING"]},
                    "description": "Sentinel-1 orbit directions."
                },
                "geometricCorrection": {"enum": ["NONE", "ELLIPSOID", "TERRAIN"], "description": "Sentinel-1 geometric correction."},
                "speckleFilter": {"enum": ["NONE", "BOXCAR", "LEE", "REFINED_LEE", "LEE_SIGMA", "GAMMA_MAP"]},
                "outlierRemoval": {"enum": ["NONE", "MODERATE", "AGGRESSIVE", "CONSERVATIVE"]},
                "orbitOverlap": {"enum": ["KEEP", "REMOVE"]},
                "tileOverlap": {"enum": ["KEEP", "QUICK_REMOVE", "REMOVE"]},
                "compose": {"enum": ["MEDOID", "MEDIAN"]},
                "snowMasking": {"enum": ["ON", "OFF"]},
                "cloudThreshold": {"type": "number", "minimum": 0, "maximum": 1, "description": "Planet cloud-score threshold (fraction)."},
                "shadowThreshold": {"type": "number", "minimum": 0, "maximum": 1},
                "cloudBuffer": {"type": "integer", "minimum": 0},
                "histogramMatching": {"enum": ["ENABLED", "DISABLED"]}
            }
        }
    }
}

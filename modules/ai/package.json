{
    "name": "ai",
    "version": "1.0.0",
    "description": "MCP and chat server for SEPAL recipe interaction via chat",
    "main": "main.js",
    "scripts": {
        "test": "jest",
        "testWatch": "jest --watchAll",
        "coverage": "jest --coverage",
        "test:manual": "jest --testPathPattern=\\.manual\\.test\\.js$ --testPathIgnorePatterns=/node_modules/ --forceExit"
    },
    "jest": {
        "collectCoverageFrom": [
            "src/chat/conversation/**/*.js",
            "src/chat/tools/**/*.js",
            "src/chat/specialists/**/*.js",
            "src/chat/llm/**/*.js",
            "src/chat/llmText/**/*.js",
            "src/chat/toolCallGuard.js",
            "src/server.js",
            "src/eventBus.js",
            "src/tracer.js",
            "src/logListener.js"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "\\.manual\\.test\\.js$"
        ]
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.95.1",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "commander": "^14.0.3",
        "ioredis": "^5.10.1",
        "lodash": "^4.18.1",
        "log4js": "^6.9.1",
        "moment": "^2.30.1",
        "openai": "^6.37.0",
        "rxjs": "^7.8.2",
        "sepal": "../../lib/js/shared",
        "uuid": "^14.0.0"
    },
    "imports": {
        "#sepal/recipe": "sepal/src/recipe/index.js",
        "_comment_sepal_recipe": "Specific entry: Node imports map needs an explicit key when the target is a directory (recipe/index.js), since #sepal/* would otherwise resolve to recipe.js.",
        "#sepal/*": "sepal/src/*.js",
        "#sepal/*.json": "sepal/src/*.json",
        "#mcp/*": "./src/*.js",
        "#mcp/*.json": "./src/*.json",
        "#config/*.json": "./config/*.json"
    },
    "devDependencies": {
        "jest": "^29.7.0"
    }
}

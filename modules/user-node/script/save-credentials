#!/bin/sh
# save-credentials <username>   (credentials JSON read from stdin)
# Writes /sepal/home/<username>/.config/earthengine/credentials owned root:<gid-of-data-home>,
# mirroring the Java GoogleAccessTokenFileGateway. Runs as root via sudo (node stays non-root).
set -e

username="$1"
case "$username" in
    "" | *[!A-Za-z0-9_]* ) echo "invalid username: $username" >&2; exit 2 ;;
esac

data_home="/sepal/home/$username"
config_dir="$data_home/.config"
ee_dir="$config_dir/earthengine"
cred="$ee_dir/credentials"
lock="$ee_dir/.lock"

[ -d "$data_home" ] || { echo "no data home for $username" >&2; exit 3; }
gid=$(stat -c '%g' "$data_home")

mkdir -p "$ee_dir"
cat > "$cred"                      # stdin -> credentials file
[ -f "$lock" ] || : > "$lock"

chown "root:$gid" "$config_dir"; chmod 1777 "$config_dir"
chown "root:$gid" "$ee_dir";     chmod 1777 "$ee_dir"
chown "root:$gid" "$cred";       chmod 644 "$cred"
chown "root:$gid" "$lock"
